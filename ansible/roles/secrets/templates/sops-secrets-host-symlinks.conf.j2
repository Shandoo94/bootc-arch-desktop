# Managed by Ansible - sops-secrets role
# Creates host-specific symlinks for {{ hostname }} to decrypted secrets in {{ secrets_runtime_dir }}

{% macro render_paths(paths, runtime_dir, prefix='') %}
{% for key, value in paths.items() %}
{% if value is string %}
# {{ prefix }}{{ key }} -> {{ value }}
d {{ value | dirname }} 0755 root root -
L+ {{ value }} - - - - {{ runtime_dir }}/{{ (prefix ~ key) | replace('.', '/') }}
{% else %}
{{ render_paths(value, runtime_dir, prefix ~ key ~ '.') }}
{% endif %}
{% endfor %}
{% endmacro %}

{% if secrets_paths[hostname] is defined %}
# Host-specific secrets symlinks for {{ hostname }}
{{ render_paths(secrets_paths[hostname], secrets_runtime_dir ~ '/host') }}
{% endif %}
