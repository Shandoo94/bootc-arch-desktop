#!/bin/bash
set -euo pipefail

# Configuration
export SOPS_AGE_KEY_FILE="{{ secrets_age_key_path }}"
SECRETS_SOURCE_DIR="{{ secrets_source_dir }}"
RUNTIME_SECRETS_DIR="{{ secrets_runtime_dir }}"
GLOBAL_DIR="${RUNTIME_SECRETS_DIR}/share"
HOST_DIR="${RUNTIME_SECRETS_DIR}/host"
HOSTNAME="{{ container_hostname }}"

# Logging functions
log() { echo "[sops-secrets] $*" >&2; }
error() { log "ERROR: $*"; }
warn() { log "WARNING: $*"; }

# Check prerequisites
if [[ ! -f "$SOPS_AGE_KEY_FILE" ]]; then
  error "Age key not found at $SOPS_AGE_KEY_FILE"
  error "System will boot without decrypted secrets"
  exit 1
fi

if [[ ! -f "$SECRETS_SOURCE_DIR/global_secrets.yaml" ]]; then
  warn "Global secrets not found at $SECRETS_SOURCE_DIR/global_secrets.yaml"
fi

if [[ ! -f "$SECRETS_SOURCE_DIR/host_secrets.yaml" ]]; then
  warn "Host secrets not found at $SECRETS_SOURCE_DIR/host_secrets.yaml"
fi

# Create runtime directories
mkdir -p "$GLOBAL_DIR" "$HOST_DIR"
chmod 0755 "$GLOBAL_DIR" "$HOST_DIR"

log "Decrypting secrets for host: $HOSTNAME"

# Function: Recursively convert YAML hierarchy to file tree
# Args: $1=key_path, $2=value, $3=target_dir
write_secret_file() {
  local key_path="$1"
  local value="$2"
  local target_dir="$3"
  
  # Convert dot notation to path: "user_pw.tiwaz" -> "user_pw/tiwaz"
  local file_path="${target_dir}/${key_path}"
  local dir_path
  dir_path=$(dirname "$file_path")
  
  # Create parent directories
  mkdir -p "$dir_path"
  chmod 0755 "$dir_path"
  
  # Write value to file
  echo -n "$value" > "$file_path"
  chmod 0400 "$file_path"
  
  log "Created secret: ${file_path#$RUNTIME_SECRETS_DIR/}"
}

# Function: Process YAML and extract all leaf values
# Args: $1=yaml_file, $2=target_dir, $3=key_prefix (optional)
process_yaml_secrets() {
  local yaml_file="$1"
  local target_dir="$2"
  local key_prefix="${3:-}"
  
  if [[ ! -f "$yaml_file" ]]; then
    warn "Secrets file not found: $yaml_file"
    return 1
  fi
  
  # Decrypt YAML file and remove sops metadata
  local decrypted_yaml
  if ! decrypted_yaml=$(sops -d "$yaml_file" 2>&1); then
    error "Failed to decrypt $yaml_file: $decrypted_yaml"
    return 1
  fi
  
  # Filter out sops metadata section
  decrypted_yaml=$(echo "$decrypted_yaml" | yq -y 'del(.sops)')
  
  # If key_prefix is provided, extract only that subtree
  if [[ -n "$key_prefix" ]]; then
    decrypted_yaml=$(echo "$decrypted_yaml" | yq -y ".${key_prefix} // {}")
    if [[ "$decrypted_yaml" == "{}" || "$decrypted_yaml" == "null" ]]; then
      log "No secrets found for prefix: $key_prefix"
      return 0
    fi
  fi
  
  # Extract all leaf key-value pairs using jq to get paths
  # Use yq with -r for raw output, paths(scalars) gets all paths to leaf values
  local keys
  keys=$(echo "$decrypted_yaml" | yq -r 'paths(scalars) | join(".")')
  
  if [[ -z "$keys" ]]; then
    log "No secrets to process"
    return 0
  fi
  
  # Process each key-value pair
  while IFS= read -r key; do
    if [[ -n "$key" ]]; then
      # Get the value for this key using jq path syntax
      local value
      value=$(echo "$decrypted_yaml" | yq -r ".${key}")
      
      # Convert dots in key to path separators
      local file_key="${key//./\/}"
      
      # Write secret file
      write_secret_file "$file_key" "$value" "$target_dir"
    fi
  done <<< "$keys"
}

# Decrypt global secrets
if [[ -f "$SECRETS_SOURCE_DIR/global_secrets.yaml" ]]; then
  log "Decrypting global secrets..."
  if process_yaml_secrets "$SECRETS_SOURCE_DIR/global_secrets.yaml" "$GLOBAL_DIR"; then
    log "Global secrets decrypted successfully"
  else
    error "Failed to decrypt global secrets"
  fi
else
  warn "Skipping global secrets (file not found)"
fi

# Decrypt host-specific secrets
if [[ -f "$SECRETS_SOURCE_DIR/host_secrets.yaml" ]]; then
  log "Decrypting host-specific secrets..."
  if process_yaml_secrets "$SECRETS_SOURCE_DIR/host_secrets.yaml" "$HOST_DIR" "$HOSTNAME"; then
    log "Host-specific secrets decrypted successfully"
  else
    error "Failed to decrypt host-specific secrets for $HOSTNAME"
  fi
else
  warn "Skipping host-specific secrets (file not found)"
fi

log "Secrets decryption process completed"
exit 0
