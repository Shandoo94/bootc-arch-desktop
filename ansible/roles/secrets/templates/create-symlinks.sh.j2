#!/bin/bash
set -euo pipefail

SECRETS_SOURCE_DIR="{{ secrets_source_dir }}"
HOSTNAME=$(cat /etc/hostname)
LOG_PREFIX="[sops-secrets-symlinks]"

log() { echo "$LOG_PREFIX $*" >&2; }

HOST_CONF="${SECRETS_SOURCE_DIR}/tmpfiles.d/sops-secrets-${HOSTNAME}.conf"
if [[ -f "$HOST_CONF" ]]; then
    log "Applying symlinks for host: $HOSTNAME"
    systemd-tmpfiles --create "$HOST_CONF"
else
    log "No host-specific symlinks for: $HOSTNAME"
fi

log "Symlink creation completed"
