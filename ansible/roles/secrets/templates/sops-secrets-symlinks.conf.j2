# Managed by Ansible - sops-secrets role
# Creates symlinks from configured paths to decrypted secrets in {{ secrets_runtime_dir }}

{% macro render_paths(paths, runtime_dir, prefix='') %}
{% for key, value in paths.items() %}
{% if value is string %}
# {{ prefix }}{{ key }} -> {{ value }}
d {{ value | dirname }} 0755 root root -
L+ {{ value }} - - - - {{ runtime_dir }}/{{ (prefix ~ key) | replace('.', '/') }}
{% else %}
{{ render_paths(value, runtime_dir, prefix ~ key ~ '.') }}
{% endif %}
{% endfor %}
{% endmacro %}

{% if secrets_paths.global is defined %}
# Global secrets symlinks
{{ render_paths(secrets_paths.global, secrets_runtime_dir ~ '/share') }}
{% endif %}

{% if secrets_paths[container_hostname] is defined %}
# Host-specific secrets symlinks for {{ container_hostname }}
{{ render_paths(secrets_paths[container_hostname], secrets_runtime_dir ~ '/host') }}
{% endif %}
