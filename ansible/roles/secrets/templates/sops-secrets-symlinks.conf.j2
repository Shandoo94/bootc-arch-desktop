# Managed by Ansible - sops-secrets role
# Creates symlinks from configured paths to decrypted secrets in {{ secrets_config.runtime_secrets_dir }}

{% if secrets_config.paths.global is defined and secrets_config.paths.global | length > 0 %}
# Global secrets symlinks
{% for secret_key, symlink_path in secrets_config.paths.global.items() %}
# Create parent directory for {{ symlink_path }}
d {{ symlink_path | dirname }} 0755 root root -
# Symlink {{ secret_key }} -> {{ symlink_path }}
L+ {{ symlink_path }} - - - - {{ secrets_config.runtime_global_dir }}/{{ secret_key | replace('.', '/') }}
{% endfor %}
{% endif %}

{% if secrets_config.paths[inventory_hostname] is defined and secrets_config.paths[inventory_hostname] | length > 0 %}
# Host-specific secrets symlinks for {{ inventory_hostname }}
{% for secret_key, symlink_path in secrets_config.paths[inventory_hostname].items() %}
# Create parent directory for {{ symlink_path }}
d {{ symlink_path | dirname }} 0755 root root -
# Symlink {{ secret_key }} -> {{ symlink_path }}
L+ {{ symlink_path }} - - - - {{ secrets_config.runtime_host_dir }}/{{ secret_key | replace('.', '/') }}
{% endfor %}
{% endif %}
