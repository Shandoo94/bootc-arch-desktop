[Unit]
Description=Decrypt SOPS secrets at boot
DefaultDependencies=no
# Run before sysusers creates users (they may need passwords)
Before=systemd-sysusers.service
RequiresMountsFor=/var /usr /run

[Service]
Type=oneshot
ExecStart=/usr/local/bin/decrypt-secrets
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=systemd-sysusers.service
