#!/usr/bin/env bash
set -euo pipefail

USER_DATA_FILE="${1:-{{ user_creation_source_dir }}/user-data.yaml}"

log_info() {
    echo "[INFO] $1" | systemd-cat -t bootc-user-passwords -p info
}

log_warn() {
    echo "[WARN] $1" | systemd-cat -t bootc-user-passwords -p warning
}

log_error() {
    echo "[ERROR] $1" | systemd-cat -t bootc-user-passwords -p err
}

if [[ ! -f "$USER_DATA_FILE" ]]; then
    log_warn "User data file not found: $USER_DATA_FILE"
    exit 0
fi

if ! command -v yq &> /dev/null; then
    log_error "yq is required but not installed"
    exit 1
fi

if [[ ! -s "$USER_DATA_FILE" ]]; then
    log_warn "User data file is empty: $USER_DATA_FILE"
    exit 0
fi

USER_COUNT=$(yq 'length' "$USER_DATA_FILE" 2>/dev/null) || {
    log_error "Failed to parse user data file: $USER_DATA_FILE"
    exit 1
}

if [[ "$USER_COUNT" -eq 0 ]]; then
    log_info "No users configured in $USER_DATA_FILE"
    exit 0
fi

for i in $(seq 0 $((USER_COUNT - 1))); do
    USER=$(yq ".[$i].name" "$USER_DATA_FILE" 2>/dev/null)
    PW_FILE=$(yq ".[$i].hashed_pw_file" "$USER_DATA_FILE" 2>/dev/null)

    if [[ -z "$USER" || "$USER" == "null" ]]; then
        log_warn "Skipping entry $i with missing username"
        continue
    fi

    if ! id "$USER" &>/dev/null; then
        log_warn "User '$USER' does not exist, skipping password set"
        continue
    fi

    if [[ ! -f "$PW_FILE" ]]; then
        log_warn "Password file for user '$USER' not found: $PW_FILE, skipping"
        continue
    fi

    PW_HASH=$(cat "$PW_FILE")
    if [[ -z "$PW_HASH" ]]; then
        log_error "Password file for user '$USER' is empty: $PW_FILE"
        continue
    fi

    if echo "${USER}:${PW_HASH}" | chpasswd -e 2>/dev/null; then
        log_info "Successfully set password for user '$USER'"
    else
        log_error "Failed to set password for user '$USER'"
    fi
done

exit 0
