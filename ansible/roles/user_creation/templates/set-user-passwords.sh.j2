#!/usr/bin/env bash
set -euo pipefail

log_info() {
    echo "[INFO] $1" | systemd-cat -t bootc-user-passwords -p info
}

log_error() {
    echo "[ERROR] $1" | systemd-cat -t bootc-user-passwords -p err
}

log_info "Starting password configuration for {{ user_creation_users | length }} user(s)"

{% for user in user_creation_users %}
# Set password for user: {{ user.name }}
if [[ -f "{{ user.hashed_pw_file }}" ]]; then
    PW_HASH=$(cat '{{ user.hashed_pw_file }}')
    if echo "{{ user.name }}:${PW_HASH}" | chpasswd -e -; then
        log_info "Successfully set password for user '{{ user.name }}'"
    else
        log_error "Failed to set password for user '{{ user.name }}'"
    fi
else
    log_error "Password file not found for user '{{ user.name }}': {{ user.hashed_pw_file }}"
fi

{% endfor %}
log_info "Password configuration complete"
exit 0
