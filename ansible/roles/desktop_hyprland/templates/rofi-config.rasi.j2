* {
  font:                        "{{ theme_data.font.style.mono }}";
  background:                  {{ theme_data.colors.base00 }};
  background-alt:              {{ theme_data.colors.base01 }};
  foreground:                  {{ theme_data.colors.base05 }};
  selected:                    {{ theme_data.colors.base0D }};
  active:                      {{ theme_data.colors.base06 }};
  urgent:                      {{ theme_data.colors.base08 }};
}

imagebox {
  background-image: url("{{ theme_data.wallpaper_path }}", width);
}

/*****----- Configuration -----*****/
configuration {
	modi:                       "drun,run,filebrowser,window";
  show-icons:                 true;
  display-drun:               "Apps";
  display-run:                "Run";
  display-filebrowser:        "Files";
  display-window:             "Windows";
	drun-display-format:        "{name}";
	window-format:              "{w} · {c} · {t}";
  me-select-entry:            "MouseSecondary";
  me-accept-entry:            "MousePrimary";
}

/*****----- Main Window -----*****/
window {
    /* properties for window widget */
    transparency:             "real";
    location:                 center;
    anchor:                   center;
    fullscreen:               false;
    width:                    1000px;
    height:                   700px;
    x-offset:                 0px;
    y-offset:                 0px;
    border-color:             @selected;

    /* properties for all widgets */
    enabled:                  true;
    border-radius:            15px;
    cursor:                   "default";
    background-color:         @background;
}

/*****----- Main Box -----*****/
mainbox {
    enabled:                  true;
    spacing:                  0px;
    margin:                   -5px;
    background-color:         transparent;
    orientation:              vertical;
    children:                 [ "imagebox", "listbox" ];
}

imagebox {
    padding:                  35px 20px 60px;
    spacing:                  20px;
    height:                   200px;
    expand:                   false;
    background-color:         transparent;
    orientation:              vertical;
    children:                 [ "inputbar", "dummy", "mode-switcher" ];
}

listbox {
    spacing:                  20px;
    padding:                  20px;
    background-color:         transparent;
    orientation:              vertical;
    children:                 [ "message", "listview" ];
}

dummy {
    background-color:         transparent;
}

/*****----- Inputbar -----*****/
inputbar {
    enabled:                  true;
    spacing:                  0px;
    margin:                   0px;
    padding:                  15px 0px 15px 0px;
    border-radius:            20px;
    border-color:             gray/20%;
    background-color:         @background-alt;
    children:                 [ "entry" ];
}

entry {
    enabled:                  true;
    background-color:         @background-alt;
    text-color:               @foreground;
    cursor:                   text;
    placeholder:              "Search";
    placeholder-color:        inherit;
    vertical-align:           0.5;
    horizontal-align:         0.5;
}

/*****----- Mode Switcher -----*****/
mode-switcher{
    enabled:                  true;
    spacing:                  20px;
    background-color:         transparent;
    text-color:               @foreground;
}
button {
    padding:                  6px;
    border:                   0px solid;
    border-radius:            100%;
    background-color:         @background-alt;
    text-color:               inherit;
    cursor:                   pointer;
}
button selected {
    background-color:         @selected;
    text-color:               @foreground;
}

/*****----- Listview -----*****/
listview {
    enabled:                  true;
    columns:                  2;
    lines:                    4;
    cycle:                    true;
    dynamic:                  true;
    scrollbar:                false;
    layout:                   vertical;
    reverse:                  false;
    fixed-height:             true;
    fixed-columns:            true;
    
    spacing:                  5px;
    margin:                   0px;
    padding:                  0px;
    border:                   0px solid;
    background-color:         transparent;
    text-color:               @foreground;
    cursor:                   "default";
}

/*****----- Elements -----*****/
element {
    enabled:                  true;
    spacing:                  10px;
    margin:                   10px;
    padding:                  10px;
    border:                   3px solid;
    border-radius:            8px;
    border-color:             @background-alt;
    background-color:         @background;
    text-color:               @foreground;
    cursor:                   pointer;
}

element normal normal,
element alternate.normal {
    background-color:         @background-alt;
}

element-text selected,
element selected.normal {
    background-color:         @selected;
    text-color:               @foreground;
}

element selected.active {
    background-color:         @urgent;
    text-color:               @foreground;
}

element-icon {
    background-color:         transparent;
    size:                     33px;
    cursor:                   inherit;
}

element-text {
    background-color:         inherit;
    text-color:               inherit;
    cursor:                   inherit;
    vertical-align:           0.5;
    horizontal-align:         0.0;
}

/*****----- Message -----*****/
message {
    background-color:         transparent;
}
textbox {
    padding:                  10px;
    background-color:         @background-alt;
    text-color:               inherit;
    vertical-align:           0.5;
    horizontal-align:         0.0;
}
error-message {
    padding:                  10px;
}
